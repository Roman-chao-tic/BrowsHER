{
  "manifest_version": 3,
  "name": "browsHER",
  "version": "1.0",
  "description": "Custom glassy new tab homepage with emotions, facts, day/night.",
  "chrome_url_overrides" : {
    "newtab": "index.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
